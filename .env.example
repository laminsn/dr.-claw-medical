# ============================================================
# .env.example — Environment Variables Template
# ============================================================
#
# HOW TO USE:
# 1. Copy this file and rename it to .env:
#      cp .env.example .env
# 2. Fill in each value below with your actual API keys
# 3. Never commit your .env file to git (it contains secrets!)
#
# ============================================================


# ─── SUPABASE (already configured for this project) ─────────
# These are public/publishable keys — safe to share
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"


# ─── DEEPGRAM (Speech-to-Text) ──────────────────────────────
# Deepgram converts your voice to text in real-time.
#
# WHERE TO GET IT:
# 1. Go to https://console.deepgram.com
# 2. Sign up for a free account (comes with $200 in credits!)
# 3. Go to "API Keys" in the left sidebar
# 4. Click "Create a New API Key"
# 5. Give it a name like "Dr Claw Medical"
# 6. Copy the key and paste it below
#
DEEPGRAM_API_KEY="your-deepgram-api-key-here"


# ─── OPENAI (AI Brain — GPT-4o-mini) ────────────────────────
# OpenAI's GPT-4o-mini is the AI that generates responses.
#
# WHERE TO GET IT:
# 1. Go to https://platform.openai.com
# 2. Sign up or log in
# 3. Go to "API keys" (https://platform.openai.com/api-keys)
# 4. Click "Create new secret key"
# 5. Give it a name like "Dr Claw Medical"
# 6. Copy the key and paste it below
# 7. IMPORTANT: Add billing info at https://platform.openai.com/settings/organization/billing
#    (GPT-4o-mini is very cheap — about $0.15 per million input tokens)
#
OPENAI_API_KEY="sk-your-openai-api-key-here"


# ─── TAVUS (Video Avatar — CVI) ─────────────────────────────
# Tavus creates a talking AI video avatar with real-time lip-sync.
#
# WHERE TO GET YOUR API KEY:
# 1. Go to https://platform.tavus.io
# 2. Sign up for an account
# 3. Navigate to "API Keys" in your dashboard
# 4. Create a new API key and paste it below
#
TAVUS_API_KEY="your-tavus-api-key-here"

# WHERE TO GET YOUR REPLICA ID:
# 1. In the Tavus dashboard, go to "Replicas"
# 2. Create a new replica (record a video of yourself)
#    OR use one of Tavus's stock replicas
# 3. Click on the replica → copy the "Replica ID"
# 4. It looks like: r7a8b9c0-1234-5678-abcd-ef1234567890
#
TAVUS_REPLICA_ID="your-tavus-replica-id-here"

# WHERE TO GET YOUR PERSONA ID:
# 1. In the Tavus dashboard, go to "Personas"
# 2. Create a new persona (defines the avatar's personality)
#    - Set a name like "Dr. Claw Medical Assistant"
#    - Write a system prompt for how the avatar should behave
#    - Choose the LLM (you can use GPT-4o-mini here too)
# 3. Copy the "Persona ID"
# 4. It looks like: p1a2b3c4-5678-9012-cdef-ab1234567890
#
TAVUS_PERSONA_ID="your-tavus-persona-id-here"


# ─── SERVER PORT (optional) ─────────────────────────────────
# The Express API server port (default: 3001)
# The frontend runs on port 8080 (via Vite)
# PORT=3001
